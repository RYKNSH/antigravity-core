#!/bin/bash
# Pre-commit hook for Antigravity
# Prevents committing personal files and secrets

echo "🔍 Pre-commit check..."

# Check 1: personal/配下のファイル（README除く）
PERSONAL_FILES=$(git diff --cached --name-only | grep "^personal/" | grep -v "personal/README.md" | grep -v "personal/.gitkeep")
if [ -n "$PERSONAL_FILES" ]; then
  echo "❌ Error: Files in personal/ cannot be committed"
  echo ""
  echo "Found:"
  echo "$PERSONAL_FILES"
  echo ""
  echo "💡 Tip: Move to contrib/ if you want to share:"
  echo "   mv personal/my-file.md contrib/workflows/my-file.md"
  exit 1
fi

# Check 2: Secretsパターン（.env.shared.tpl / docker-compose.yml はテンプレートなので除外）
SECRET_PATTERNS="API_KEY|SECRET|PASSWORD|TOKEN|PRIVATE_KEY|ACCESS_TOKEN"
SECRET_HITS=$(git diff --cached -- ':!.env.shared.tpl' ':!media/penpot/docker-compose.yml' ':!media/penpot/.env.example' | grep -iE "($SECRET_PATTERNS)=")
if [ -n "$SECRET_HITS" ]; then
  echo "⚠️  Warning: Potential secret detected"
  echo ""
  echo "$SECRET_HITS" | head -5
  echo ""
  # TTYがない環境（AI実行時等）は自動綞切
  if [ -t 0 ]; then
    read -p "Continue anyway? (y/n): " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
      echo "❌ Commit aborted"
      exit 1
    fi
  else
    echo "❌ Commit aborted (non-interactive mode)"
    exit 1
  fi
fi

# Check 3: credentials/配下のファイル（.gitkeep除く）
CRED_FILES=$(git diff --cached --name-only | grep "^credentials/" | grep -v "credentials/.gitkeep")
if [ -n "$CRED_FILES" ]; then
  echo "❌ Error: Files in credentials/ cannot be committed"
  echo ""
  echo "Found:"
  echo "$CRED_FILES"
  echo ""
  echo "💡 Tip: credentials/ is for local secrets only"
  exit 1
fi

echo "✅ Pre-commit check passed"
