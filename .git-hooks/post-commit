#!/bin/bash
# post-commit hook: auto-update CONTEXT_HEAD with latest commit info
# Skips ctx: commits to prevent infinite loop

LAST_MSG=$(git log --format=%s -1)
[[ "$LAST_MSG" == ctx:* ]] && exit 0

HEAD_FILE="$HOME/.antigravity/context-log/CONTEXT_HEAD.yaml"
[ -f "$HEAD_FILE" ] || exit 0

HASH=$(git rev-parse --short HEAD)
TS=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

# Append/update last_code_commit fields
if grep -q "^last_code_commit:" "$HEAD_FILE" 2>/dev/null; then
  sed -i.bak "s/^last_code_commit:.*/last_code_commit: $HASH/" "$HEAD_FILE" && rm -f "$HEAD_FILE.bak"
else
  echo "last_code_commit: $HASH" >> "$HEAD_FILE"
fi

if grep -q "^last_code_commit_at:" "$HEAD_FILE" 2>/dev/null; then
  sed -i.bak "s/^last_code_commit_at:.*/last_code_commit_at: $TS/" "$HEAD_FILE" && rm -f "$HEAD_FILE.bak"
else
  echo "last_code_commit_at: $TS" >> "$HEAD_FILE"
fi

# Assert success, otherwise generate telemetry alert
if [ $? -ne 0 ]; then
  mkdir -p "$HOME/.antigravity/state"
  echo "- [$(date -u +"%Y-%m-%dT%H:%M:%SZ")] [System Error] post-commit hook failed to update CONTEXT_HEAD" >> "$HOME/.antigravity/state/SYSTEM_ALERTS.md"
fi

